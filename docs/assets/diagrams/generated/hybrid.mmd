classDiagram
  direction LR
  %% flet-toastify generated architecture diagrams: hybrid modules and classes

  class flet_toastify_components {
    <<module>>
    +module flet_toastify.components
    +class CardVisual
    +card_offset_px()
    +stack_coordinates()
    +row_alignment()
    +card_visual()
    +build_card()
    +position_wrapper()
    +ToastCard()
    +Toaster()
  }

  class flet_toastify_models {
    <<module>>
    +module flet_toastify.models
    +class Toast
  }

  class flet_toastify_state {
    <<module>>
    +module flet_toastify.state
    +class Toasts
  }

  class flet_toastify_style {
    <<module>>
    +module flet_toastify.style
    +class ToastStyle
  }

  class flet_toastify_types {
    <<module>>
    +module flet_toastify.types
    +class ToastType
    +class ToastPhase
    +class Position
  }

  class CardVisual {
    +float opacity
    +float scale
    +ft.Offset offset
    +ft.Animation animate_opacity
    +ft.Animation animate_scale
    +ft.Animation animate_offset
  }

  class Toast {
    +str | ft.Control content
    +ToastType type
    +int duration_ms
    +ToastPhase phase
    +str id
    +ToastStyle? style
    +with_phase(phase)
  }

  class Toasts {
    +show(content)
    +info(content)
    +success(content)
    +warning(content)
    +error(content)
    +dismiss(toast_id)
    +clear()
  }

  class ToastStyle {
    +int height
    +int width
    +int spacing
    +int border_radius
    +int padding
    +ft.AnimationCurve position_curve
    +int in_duration
    +ft.Offset in_offset
    +ft.AnimationCurve in_offset_curve
    +float in_opacity
    +ft.AnimationCurve in_opacity_curve
    +float in_scale
    +ft.AnimationCurve in_scale_curve
    +int out_duration
    +ft.Offset out_offset
    +ft.AnimationCurve out_offset_curve
    +float out_opacity
    +ft.AnimationCurve out_opacity_curve
    +float out_scale
    +ft.AnimationCurve out_scale_curve
    +dict~ToastType, ft.ColorValue~ bgcolors
    +dict~ToastType, ft.IconData~ icons
    +dict~ToastType, ft.ColorValue~ icon_colors
    +dict~ToastType, ft.ColorValue~ text_colors
    +bgcolor_for(type)
    +icon_for(type)
    +icon_color_for(type)
    +text_color_for(type)
  }

  class Position {
    +Any TOP_LEFT
    +Any TOP_CENTER
    +Any TOP_RIGHT
    +Any BOTTOM_LEFT
    +Any BOTTOM_CENTER
    +Any BOTTOM_RIGHT
  }

  class ToastPhase {
    +Any ENTERING
    +Any VISIBLE
    +Any LEAVING
  }

  class ToastType {
    +Any INFO
    +Any SUCCESS
    +Any WARNING
    +Any ERROR
  }

  flet_toastify_components ..> CardVisual
  flet_toastify_models ..> Toast
  flet_toastify_state ..> Toasts
  flet_toastify_style ..> ToastStyle
  flet_toastify_types ..> Position
  flet_toastify_types ..> ToastPhase
  flet_toastify_types ..> ToastType
  Toast ..> ToastPhase
  Toast ..> ToastStyle
  Toast ..> ToastType
  Toasts ..> Toast
  Toasts ..> ToastPhase
  Toasts ..> ToastStyle
  ToastStyle ..> Toast
  ToastStyle ..> ToastType
  flet_toastify_components --> flet_toastify_models
  flet_toastify_components --> flet_toastify_state
  flet_toastify_components --> flet_toastify_style
  flet_toastify_components --> flet_toastify_types
  flet_toastify_models --> flet_toastify_style
  flet_toastify_models --> flet_toastify_types
  flet_toastify_state --> flet_toastify_models
  flet_toastify_state --> flet_toastify_style
  flet_toastify_state --> flet_toastify_types
  flet_toastify_style --> flet_toastify_types
